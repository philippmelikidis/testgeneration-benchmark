# Copy to .env and adjust. Loaded by config/settings.py.

# --- LLM provider selection ---
# One of: ollama | openai | gemini
TCGEN_LLM_PROVIDER=ollama

# --- Ollama (local, default, free) ---
TCGEN_OLLAMA_BASE_URL=http://localhost:11434
# Ollama Cloud (hosted): set BASE_URL=https://ollama.com, add a key, and use a
# cloud model (e.g. gpt-oss:120b). Leave the key empty for a local daemon.
TCGEN_OLLAMA_API_KEY=
# Disable visible reasoning for thinking models (glm-5.1, gpt-oss) so the code
# isn't truncated/buried in the reasoning stream. Set true only to inspect CoT.
TCGEN_OLLAMA_THINK=false
TCGEN_OLLAMA_MODEL=qwen2.5-coder:7b
# Model used by the DeepEval judge. Prefer a DIFFERENT model family than the
# generator (above) to reduce LLM-as-judge in-family bias, e.g. llama3.1:8b.
TCGEN_OLLAMA_JUDGE_MODEL=qwen2.5:14b

# --- OpenAI (optional, set provider=openai to use) ---
TCGEN_OPENAI_API_KEY=
TCGEN_OPENAI_MODEL=gpt-4o
TCGEN_OPENAI_JUDGE_MODEL=gpt-4o

# --- Generation limits ---
TCGEN_LLM_TEMPERATURE=0.1
# Keep high for thinking models (glm-5.1, gpt-oss): reasoning + code must fit.
TCGEN_LLM_MAX_TOKENS=8192
TCGEN_AGENT_MAX_STEPS=25
TCGEN_AGENT_REPAIR=true

# --- Agent browser backend ---
# playwright_mcp: explore via the official Playwright MCP server (needs Node 18+/
# npx); inprocess: bundled in-process Playwright harness. MCP auto-falls back to
# inprocess (recorded in script meta) if the server cannot be launched.
TCGEN_AGENT_BROWSER_BACKEND=playwright_mcp
TCGEN_PLAYWRIGHT_MCP_COMMAND=npx
TCGEN_PLAYWRIGHT_MCP_ARGS=@playwright/mcp@latest --headless --isolated --browser chromium
# Generous: the first run lets npx download @playwright/mcp.
TCGEN_PLAYWRIGHT_MCP_START_TIMEOUT_S=90

# --- Crawler exploration ---
TCGEN_CRAWLER_MAX_STATES=40
TCGEN_CRAWLER_MAX_DEPTH=4
TCGEN_CRAWLER_MAX_ACTIONS_PER_STATE=12
TCGEN_CRAWLER_MAX_SCENARIOS=12
# Per-action timeout during exploration (ms): bounds how long a click/fill waits
# for an element to become actionable. On a local SPA real elements respond well
# under this; a longer value only wastes time on non-actionable elements. Plus a
# wall-clock cap (s; 0 = no cap, the default — the crawler is the completeness
# baseline and may run as long as it needs).
TCGEN_CRAWLER_ACTION_TIMEOUT_MS=4000
TCGEN_CRAWLER_TIME_BUDGET_S=0

# --- Execution ---
TCGEN_HEADLESS=true
TCGEN_FLAKINESS_RUNS=3
# Repetitions of the LLM stages + judge (aggregated to mean ± std). UI overrides.
TCGEN_REPETITIONS=1
# SPA settle waits (ms). networkidle is capped because SPAs like Juice Shop poll
# in the background and never go fully idle.
TCGEN_SETTLE_TIMEOUT_MS=1500
TCGEN_SETTLE_PAUSE_MS=400
# Per-action timeout applied by the generated test harness (ms).
TCGEN_TEST_ACTION_TIMEOUT_MS=15000
